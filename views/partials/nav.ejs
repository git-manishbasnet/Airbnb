<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
  </head>
  <body>
    <!-- Navbar: common to all pages -->
    <nav class="bg-white/90 backdrop-blur shadow-lg w-full px-8 py-4 flex items-center rounded-b-2xl mb-10 sticky top-0 z-50">
  <!-- Logo/Brand -->
  <a
    href="/"
    class="text-2xl font-extrabold tracking-tight text-green-600 flex items-center gap-2 px-3 py-1 rounded-lg transition
      <%= currentPage==='index'?'bg-green-100 shadow':'hover:bg-green-50'%>">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3l8 8-8 8-8-8 8-8z" />
    </svg>
    Airbnb
  </a>
  <!-- Main Links -->
  <% if(isLoggedIn){ %>
    <% if(user && user.userType === 'guest') { %>
    <div class="flex items-center gap-2 ml-8">
      <a
        href="/homes"
        class="px-3 py-2 rounded-lg font-medium transition
          <%= currentPage==='home'?'bg-green-100 text-green-700 shadow':'hover:bg-green-50 hover:text-green-700'%>">
        Homes-List
      </a>
      <a
        href="/bookings"
        class="px-3 py-2 rounded-lg font-medium transition
          <%= currentPage==='bookings'?'bg-green-100 text-green-700 shadow':'hover:bg-green-50 hover:text-green-700'%>">
        Bookings
      </a>
      <a
        href="/favourites"
        class="px-3 py-2 rounded-lg font-medium transition
          <%= currentPage==='favourites'?'bg-green-100 text-green-700 shadow':'hover:bg-green-50 hover:text-green-700'%>">
        Favourites </a>
        <% } else{ %>

      <a
        href="/host/host-homelist"
        class="px-3 py-2 rounded-lg font-medium transition
          <%= currentPage==='hostHomes'?'bg-green-100 text-green-700 shadow':'hover:bg-green-50 hover:text-green-700'%>">
        Host-Homes
      </a>
      <a
        href="/host/add-home"
        class="px-3 py-2 rounded-lg font-medium transition
          <%= currentPage==='add-home'?'bg-green-100 text-green-700 shadow':'hover:bg-green-50 hover:text-green-700'%>">
        Add Home
      </a>
      <% } %>
    </div>
  <% } %>
  <!-- Auth Buttons -->
  <div class="ml-auto flex items-center gap-3">
    <% if(isLoggedIn){ %>
      <form action="/logout" method="POST">
        <button
          type="submit"
          class="bg-red-500 hover:bg-red-600 text-white font-semibold px-5 py-2 rounded-lg shadow transition flex items-center gap-1"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a2 2 0 01-2 2H7a2 2 0 01-2-2V7a2 2 0 012-2h4a2 2 0 012 2v1" />
          </svg>
          Logout
        </button>
      </form>
    <% } else { %>
      <a
        href="/login"
        class="bg-blue-500 hover:bg-blue-600 text-white font-semibold px-5 py-2 rounded-lg shadow transition"
      >Login</a>
      <a
        href="/signup"
        class="bg-green-500 hover:bg-green-600 text-white font-semibold px-5 py-2 rounded-lg shadow transition"
      >Sign Up</a>
    <% } %>
  </div>
</nav>
  </body>
</html>
