<% if (errors.length > 0) { %>
  <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl mb-6 px-4 py-3 shadow flex flex-col gap-2">
    <div class="flex items-center gap-2 mb-1">
      <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12A9 9 0 1 1 3 12a9 9 0 0 1 18 0z"/>
      </svg>
      <span class="font-semibold">Please fix the following errors:</span>
    </div>
    <ul class="list-disc list-inside space-y-1 ml-2">
      <% errors.forEach(error => { %>
        <li class="text-sm"><%= error %></li>
      <% }); %>
    </ul>
  </div>
<% } %>
