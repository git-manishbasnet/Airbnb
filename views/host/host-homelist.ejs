<%- include('../partials/head') %>
</head>
<body class="bg-gradient-to-br from-green-100 via-blue-50 to-green-200 flex flex-col items-center justify-start min-h-screen text-center">
  <%- include('../partials/nav') %>
  <main class="pb-12 w-full">
    <div class="flex flex-col items-center mt-12 mb-10">
      <img src="https://cdn-icons-png.flaticon.com/512/2356/2356787.png" alt="Host Icon" class="w-20 h-20 mb-4 drop-shadow-lg">
      <h1 class="bg-gradient-to-r from-green-400 to-blue-400 text-white text-3xl font-extrabold px-10 py-5 rounded-3xl shadow-2xl mb-2 inline-block">
        Your Hosted Homes Dashboard
      </h1>
      <p class="text-gray-600 text-lg mt-2 max-w-xl">
        Welcome back! Here you can view, edit, or remove your listed homes. Keep your listings up to date and attract more guests!
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10 max-w-6xl mx-auto my-8">
      <% registeredHomes.forEach(home => { %>
        <div class="bg-white rounded-3xl shadow-xl hover:shadow-2xl transition-shadow duration-300 flex flex-col overflow-hidden border border-green-100">
          <div class="relative h-56 w-full">
            <img
              src="<%= home.photo || 'https://images.unsplash.com/photo-1629367494173-c78a56567877?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=927&q=80' %>"
              onerror="this.onerror=null;this.src='https://images.unsplash.com/photo-1629367494173-c78a56567877?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=927&q=80'"
              alt="<%= home.houseName %>"
              class="h-full w-full object-cover"
            />
            <span class="absolute top-3 right-3 bg-white/80 text-green-700 font-semibold px-3 py-1 rounded-full text-xs shadow">
              <%= home.type || 'Entire Home' %>
            </span>
          </div>
          <div class="flex-1 flex flex-col justify-between p-6">
            <div>
              <h3 class="text-xl font-bold text-blue-700 mb-2"><%= home.houseName %></h3>
              <p class="text-gray-600 text-sm mb-4 line-clamp-2">
                <%= home.location %>
              </p>
            </div>
            <div class="flex items-center justify-between mt-4">
              <span class="text-lg font-semibold text-green-700">
                $<%= home.price || '95.00' %>/night
              </span>
              <a href="/homes/<%= home._id %>" class="text-blue-600 hover:underline font-medium text-sm transition-colors">
                View Details
              </a>
            </div>
            <div class="flex space-x-4 justify-center mt-6">
              <a href="/host/edit-home/<%= home._id %>?editing=true"
                class="rounded-lg bg-blue-500 text-white py-2 px-6 font-semibold hover:bg-blue-700 transition-all shadow"
                type="button">
                Edit
              </a>
              <form action="/host/delete-home/<%= home._id %>" method="POST">
                <button
                  class="rounded-lg bg-red-500 text-white px-6 py-2 font-semibold hover:bg-red-700 transition-all shadow hover:scale-105"
                  type="submit"
                >
                  Delete
                </button>
              </form>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </main>
  <hr class="w-full max-w-6xl border-t-2 border-green-200 my-8">
</body>
</html>
