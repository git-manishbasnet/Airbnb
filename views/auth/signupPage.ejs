<%- include('../partials/head') %>
</head>
<body class="bg-gradient-to-br from-green-50 to-green-100 flex flex-col items-center min-h-screen">

  <%- include('../partials/nav') %>

 <div class="w-full max-w-md bg-white p-8 rounded-3xl shadow-2xl border border-green-100 mt-12">
  <div class="flex flex-col items-center mb-6">
    <img src="https://cdn-icons-png.flaticon.com/512/3135/3135715.png" alt="User Icon" class="w-16 h-16 mb-2 drop-shadow">
    <h1 class="text-3xl font-extrabold text-green-700 mb-1">Create Your Account</h1>
    <p class="text-gray-500 text-sm">Join us and start your journey!</p>
  </div>
  <main>
    <form action="/signup" method="POST" class="space-y-5">

      <%- include('../partials/showerrors', { errors: errors, oldInput: oldInput }) %>

      <div class="flex gap-3">

        <div class="flex-1">
          <label for="firstName" class="block text-sm font-semibold text-gray-700 mb-1">First Name</label>
          <input
            type="text"
            name="firstName"
            id="firstName"
            value="<%= oldInput.firstName %>"
            required
            placeholder="Enter your first name"
            class="w-full border border-gray-200 rounded-xl px-4 py-2 focus:outline-none focus:ring-2 focus:ring-green-400 transition shadow-sm"
          />
        </div>
        <div class="flex-1">
          <label for="lastName" class="block text-sm font-semibold text-gray-700 mb-1">Last Name</label>
          <input
            type="text"
            name="lastName"
            id="lastName"
            value="<%= oldInput.lastName %>"
            placeholder="Enter your last name"
            class="w-full border border-gray-200 rounded-xl px-4 py-2 focus:outline-none focus:ring-2 focus:ring-green-400 transition shadow-sm"
          />
        </div>
      </div>
      <div>
        <label for="email" class="block text-sm font-semibold text-gray-700 mb-1">Email</label>
        <input
          type="email"
          name="email"
          id="email"
          value="<%= oldInput.email %>"
            required
          required
          placeholder="abc123@gmail.com"
          class="w-full border border-gray-200 rounded-xl px-4 py-2 focus:outline-none focus:ring-2 focus:ring-green-400 transition shadow-sm"
        />
      </div>
      <div>
        <label for="password" class="block text-sm font-semibold text-gray-700 mb-1">Password</label>
        <input
          type="password"
          name="password"
          id="password"
          required
          placeholder="Enter your password"
          class="w-full border border-gray-200 rounded-xl px-4 py-2 focus:outline-none focus:ring-2 focus:ring-green-400 transition shadow-sm"
        />
      </div>
      <div>
        <label for="confirmPassword" class="block text-sm font-semibold text-gray-700 mb-1">Confirm Password</label>
        <input
          type="password"
          name="confirmPassword"
          id="confirmPassword"
          required
          placeholder="Re-enter your password"
          class="w-full border border-gray-200 rounded-xl px-4 py-2 focus:outline-none focus:ring-2 focus:ring-green-400 transition shadow-sm"
        />
      </div>
      <div class="flex items-center gap-6 mt-2">
        <span class="text-sm font-semibold text-gray-700">User Type:</span>
        <label class="flex items-center cursor-pointer">
          <input type="radio" name="userType" value="guest" <%= oldInput.userType === 'guest' ? 'checked' : '' %>  class="accent-green-600 mr-2">
          <span class="text-gray-700">Guest</span>
        </label>
        <label class="flex items-center cursor-pointer">
          <input type="radio" name="userType" value="host" class="accent-green-600 mr-2" <%= oldInput.userType === 'host' ? 'checked' : '' %>>
          <span class="text-gray-700">Host</span>
        </label>
      </div>
      <div class="flex items-center mt-2">
        <input type="checkbox" name="terms" id="terms" required class="accent-green-600 mr-2">
        <label for="terms" class="text-sm text-gray-600">I agree to the <a href="#" class="text-green-600 underline hover:text-green-800">terms and conditions</a></label>
      </div>
      <div class="flex items-center justify-between mt-6">
        <button
          type="submit"
          class="bg-gradient-to-r from-green-500 to-blue-400 hover:from-green-600 hover:to-blue-500 text-white font-bold px-6 py-2 rounded-xl shadow-lg transition-all duration-200 hover:scale-105"
        >
          Sign Up
        </button>
        <a href="/login" class="text-sm text-blue-600 hover:underline">Already have an account?</a>
      </div>
    </form>
</body>
</html>
