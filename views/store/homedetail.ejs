
     
   <%- include('../partials/head') %>
</head>
<body class="bg-gradient-to-br from-green-100 via-blue-50 to-green-200 flex flex-col min-h-screen font-sans text-gray-800">
  <!-- Navigation Bar -->
  <%- include('../partials/nav') %>
  <!-- Main Content -->
  <main class="flex-grow container mx-auto px- py-2">
    <!-- Sticky Page Heading -->
    <div class="text-center mb-8">
      <h1 class="text-4xl font-extrabold bg-gradient-to-r from-green-500 to-blue-400 bg-clip-text text-transparent drop-shadow-lg pb-6 ">
        Home Details
      </h1>
       <p class="text-blue-700 text-lg font-medium">Discover everything about this beautiful home!</p>
    </div>
    <!-- Home Details Card -->
    <div class="max-w-2xl mx-auto bg-white shadow-2xl rounded-3xl overflow-hidden border border-green-100 p-8 flex flex-col items-center">
      <!-- Home Name -->
      <h2 class="text-3xl font-bold text-green-700 mb-4 text-center"><%= home.houseName %></h2>
      <!-- Image -->
      <img
        src="<%= home.photo %>"
        alt="Home Photo"
        class="w-full max-h-80 object-cover rounded-2xl shadow mb-6"
      />
      <!-- Location -->
      <div class="mb-4 w-full text-center">
        <span class="block text-sm font-semibold text-gray-600">Location</span>
        <p class="text-lg text-blue-700 font-medium"><%= home.location %></p>
      </div>
      <!-- Price -->
      <div class="mb-4 w-full text-center">
        <span class="block text-sm font-semibold text-gray-600">Price</span>
        <p class="text-lg text-green-700 font-semibold">$<%= home.price %> <span class="text-sm font-normal text-gray-500">/night</span></p>
      </div>
      <!-- Rating -->
      <div class="mb-4 w-full text-center flex items-center justify-center">
        <span class="block text-sm font-semibold text-gray-600 mr-2">Rating</span>
        <span class="flex items-center text-yellow-500 text-lg font-bold">
          <svg class="w-5 h-5 mr-1" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.967a1 1 0 00.95.69h4.175c.969 0 1.371 1.24.588 1.81l-3.38 2.455a1 1 0 00-.364 1.118l1.287 3.966c.3.921-.755 1.688-1.54 1.118l-3.38-2.454a1 1 0 00-1.175 0l-3.38 2.454c-.784.57-1.838-.197-1.54-1.118l1.287-3.966a1 1 0 00-.364-1.118L2.05 9.394c-.783-.57-.38-1.81.588-1.81h4.175a1 1 0 00.95-.69l1.286-3.967z"/></svg>
          <%= home.rating %>/5
        </span>
      </div>
      <!-- Description -->
      <div class="mb-6 w-full text-center">
        <span class="block text-sm font-semibold text-gray-600">Description</span>
        <p class="text-base text-gray-700 mt-1"><%= home.description %></p>
      </div>
      <!-- Favourite Button -->
      <div class="flex items-center justify-center">
        <%- include('../partials/favouriteButton') %>
      </div>
    </div>
  </main>
  <hr class="mt-12 border-t-2 border-green-200 max-w-2xl mx-auto" />
</body>
</html>
    